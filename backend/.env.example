DATABASE_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_USERNAME=postgres.your-project-ref
DATABASE_PASSWORD=your-supabase-database-password
DATABASE_MAX_POOL_SIZE=5
DATABASE_MIN_IDLE=1
JPA_DDL_AUTO=update

TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION_MS=86400000
APP_BACKEND_BASE_URL=http://localhost:8080
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_FRONTEND_OAUTH_SUCCESS_URL=http://localhost:5173/oauth/callback
APP_FRONTEND_OAUTH_FAILURE_URL=http://localhost:5173/oauth/callback
APP_SEED_TMDB_ENABLED=false

# Email provider. Use "resend" for Resend, "smtp" for Gmail SMTP, or "auto".
APP_EMAIL_PROVIDER=auto
APP_EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=

# Set false when you want missing email config to fail instead of logging links.
APP_EMAIL_CONSOLE_FALLBACK=true
