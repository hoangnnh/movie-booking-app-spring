# Copy to backend/.env.local (or repo-root .env.local) and fill in values.
# Do not commit secrets.

# --- Database (required) ---
# Fresh deploy: empty database; Flyway applies V1..latest on startup.
# Supabase app runtime: transaction pooler (port 6543) is fine.
# Supabase / managed Postgres: prefer session/direct URL (port 5432) for first migration if Flyway locking fails.
DATABASE_URL=jdbc:postgresql://localhost:6543/movie_booking_app
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_MAX_POOL_SIZE=5
DATABASE_MIN_IDLE=1

# Schema: Flyway migrates; Hibernate only validates.
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_POSTGRESQL_TRANSACTIONAL_LOCK=true
FLYWAY_LOCK_RETRY_COUNT=50
# One-time only when upgrading an existing DB that was created with Hibernate ddl-auto=update:
# FLYWAY_BASELINE_ON_MIGRATE=true
# FLYWAY_BASELINE_VERSION=12
FLYWAY_BASELINE_ON_MIGRATE=false

# --- Runtime profile ---
# SPRING_PROFILES_ACTIVE=prod

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION_MS=86400000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- App URLs ---
APP_BACKEND_BASE_URL=https://api.example.com
APP_FRONTEND_BASE_URL=https://app.example.com

# --- TMDB (optional) ---
TMDB_API_READ_ACCESS_TOKEN=
TMDB_REGION=VN

# --- Email ---
APP_EMAIL_PROVIDER=smtp
APP_EMAIL_FROM=
EMAIL=
EMAIL_PASSWORD=
APP_EMAIL_CONSOLE_FALLBACK=false
APP_AUTH_VERIFICATION_TOKEN_EXPIRY_HOURS=24

# --- Development-only dummy accounts ---
# Keep the CSV outside Git. Format: email,password
# Example WSL path: /mnt/c/Users/your-name/Documents/email-password.txt
APP_SEED_DUMMY_USERS_ENABLED=false
APP_SEED_DUMMY_USERS_FILE=

# --- Payments ---
PAYMENT_VNPAY_ENABLED=false
PAYMENT_VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
